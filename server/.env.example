DB_PROVIDER=mongodb
MONGODB_URI=mongodb://USER:PASSWORD@HOST1:27017,HOST2:27017,HOST3:27017/todo-app?ssl=true&replicaSet=REPLICA_SET&authSource=admin&retryWrites=true&w=majority
PORT=4000
JWT_SECRET=troque-por-uma-chave-grande
BCRYPT_ROUNDS=12

# Opcional: se vazio, a API aceita qualquer origem. Em producao web, restrinja.
# Exemplo: CORS_ORIGINS=https://seu-frontend.com,https://outro-dominio.com
CORS_ORIGINS=

# Se DB_PROVIDER=supabase, use a URL do projeto e a service role key.
# Nunca exponha SUPABASE_SERVICE_ROLE_KEY no app/mobile.
SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key

# Opcional: se definido, avatares em base64 sobem para Cloudinary e o banco guarda so a URL.
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
